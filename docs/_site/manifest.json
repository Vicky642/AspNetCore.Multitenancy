        }
      },
      "version": "",
      "Uid": null,
      "IsMRef": true,
      "Title": "AspNetCore.Multitenancy.BackgroundJobs.TenantRecurringJobManager",
      "Summary": "<p sourcefile=\"api/AspNetCore.Multitenancy.BackgroundJobs.TenantRecurringJobManager.yml\" sourcestartlinenumber=\"1\">Schedules Hangfire recurring jobs for every active tenant automatically.\nUse this instead of <xref href=\"Hangfire.RecurringJob\" data-throw-if-not-resolved=\"false\"></xref> directly to ensure jobs\nrun once per tenant with a properly populated <xref href=\"AspNetCore.Multitenancy.ITenantContext\" data-throw-if-not-resolved=\"false\"></xref>.</p>\n"
    },
